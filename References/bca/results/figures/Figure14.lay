### Frame Number 3 ###
$!CREATENEWFRAME 
$!FRAMELAYOUT 
  SHOWBORDER = NO
  HEADERCOLOR = BLUE
  XYPOS
    {
    X = 0.125
    Y = 0.125
    }
  WIDTH = 8.25
  HEIGHT = 1
$!FRAMENAME  = 'Frame 003' 
$!SKETCHAXIS 
  DEPXTOYRATIO = 1
  XDETAIL
    {
