      LINETHICKNESS = 0.2
      }
    MINORTICKS
      {
      LENGTH = 0.5
      LINETHICKNESS = 0.2
      }
    TITLE
      {
      TITLEMODE = NONE
      }
    }
$!XYAXIS 
