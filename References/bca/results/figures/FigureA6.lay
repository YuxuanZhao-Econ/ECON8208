  XYPOS
    {
    X = 8.5
    Y = 83.5
    }
  ZONE = 4
  TEXTSHAPE
    {
    FONT = HELV
    HEIGHT = 19
    }
  TEXT = '\n' 
$!ATTACHTEXT 
  XYPOS
    {
