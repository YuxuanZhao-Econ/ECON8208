    Y = 27.9637685236
    }
  ZONE = 4
  TEXTSHAPE
    {
    FONT = TIMES
    HEIGHT = 15
    }
  TEXT = 'Labor Wedge' 
$!ATTACHTEXT 
  XYPOS
    {
    X = 63.1821126359
    Y = 48.8518593834
    }
  ZONE = 4
  TEXTSHAPE
    {
    FONT = TIMES
    HEIGHT = 15
    }
  TEXT = 'Efficiency Wedge' 
$!ATTACHTEXT 
  XYPOS
