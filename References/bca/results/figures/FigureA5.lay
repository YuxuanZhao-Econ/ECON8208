      {
      GEOMSHAPE = CIRCLE
      }
    COLOR = RED
    FILLCOLOR = GREEN
    SIZE = 0.75
    }
  BARCHARTS
    {
    COLOR = GREEN
    FILLCOLOR = GREEN
    }
  ERRORBARS
    {
    COLOR = GREEN
    }
